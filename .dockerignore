# Never bake secrets into the image
.env
*.env
.env.*

# Python artifacts
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Dev / test artifacts
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# Editor
.vscode/
.idea/
*.swp
*.swo

# Git
.git/
.gitignore

# Reports generated at runtime (don't embed in image)
report.txt
