# ══════════════════════════════════════════════════════════════════════════════
#  Aegis — Environment Configuration Template
#  Copy to .env and fill in values before running.
#  NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════════════════════════

# ── Environment & Safety ──────────────────────────────────────────────────────
# Identifies the runtime environment. Set to production/staging/il4/il6 to
# enable production safety guards (DEV_MODE=true will be rejected in these envs).
ENVIRONMENT=dev

# DEV_MODE=true disables OIDC JWT verification (local development only).
# FATAL error if set to true with ENVIRONMENT=production|staging|il2|il4|il5|il6
DEV_MODE=false
# ── LLM Provider ─────────────────────────────────────────────
# Default: OpenAI  →  leave OPENAI_BASE_URL empty
# Ollama (local):  →  OPENAI_BASE_URL=http://localhost:11434/v1  OPENAI_API_KEY=ollama
# LM Studio:       →  OPENAI_BASE_URL=http://localhost:1234/v1   OPENAI_API_KEY=lm-studio
# vLLM:            →  OPENAI_BASE_URL=http://localhost:8000/v1
# LocalAI:         →  OPENAI_BASE_URL=http://localhost:8080/v1
# Groq:            →  OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4.1-mini

# ── Auth (OIDC / JWT) ────────────────────────────────────────
# Your Identity Provider's issuer URL (e.g. Auth0, Okta, Keycloak, Cognito)
OIDC_ISSUER=https://your-idp.com
OIDC_AUDIENCE=aegis

# ── AWS ──────────────────────────────────────────────────────
# Uses standard AWS credential chain (env vars, ~/.aws/credentials, IAM role, etc.)
# Run `aws configure` or set these manually:
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_DEFAULT_REGION=us-east-1
AWS_ENABLED=true

# ── Azure ────────────────────────────────────────────────────
# Install SDK first: pip install azure-identity azure-mgmt-network azure-mgmt-storage
# Authenticate with: az login  OR set AZURE_CLIENT_ID / AZURE_CLIENT_SECRET / AZURE_TENANT_ID
AZURE_ENABLED=false
AZURE_SUBSCRIPTION_ID=

# ── GCP ──────────────────────────────────────────────────────
# Install SDK first: pip install google-cloud-compute
# Authenticate with: gcloud auth application-default login
GCP_ENABLED=false
GCP_PROJECT_ID=

# ── Network Scanning ─────────────────────────────────────────
# Requires: nmap binary (apt install nmap / brew install nmap)
#           python binding (pip install python-nmap)
# Targets: comma-separated IPs, hostnames, or CIDR ranges
NETWORK_SCAN_ENABLED=false
NETWORK_SCAN_TARGETS=192.168.1.0/24

# ── Search / Analytics Backend ───────────────────────────────
# "opensearch" (recommended — Apache 2.0): pip install opensearch-py
# "elasticsearch" (Elastic License fallback): pip install elasticsearch
SEARCH_BACKEND=opensearch
ELASTICSEARCH_ENABLED=false
ELASTICSEARCH_URL=http://localhost:9200

# Authentication — use API key (preferred for Elastic Cloud / ES 8.x)
# OR username + password for self-hosted:
ELASTICSEARCH_API_KEY=
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# Index name prefix (creates: aegis-findings, aegis-remediations, aegis-scans)
ELASTICSEARCH_INDEX_PREFIX=aegis

# ── Dashboard Backend ─────────────────────────────────────────
# "opensearch" = OpenSearch Dashboards (Apache 2.0, recommended)
# "kibana"     = Kibana (Elastic License)
DASHBOARD_BACKEND=opensearch
DASHBOARD_URL=http://localhost:5601
DASHBOARD_API_KEY=

# ── SIEM / Alerting ──────────────────────────────────────────
# Transport 1: Generic HTTP webhook
# Compatible with: Graylog, Wazuh, TheHive, OpenSearch Ingest, PagerDuty, custom listeners
SIEM_WEBHOOK_URL=

# Transport 2 / 3: Syslog (RFC 5424) or CEF over Syslog
# Compatible with: Graylog, rsyslog, syslog-ng, Wazuh, QRadar, OSSEC, ArcSight, LogRhythm
# Protocol: udp | tcp | tcp+tls
SIEM_SYSLOG_HOST=
SIEM_SYSLOG_PORT=514
SIEM_SYSLOG_PROTOCOL=udp

# Set to true to send CEF (Common Event Format) instead of plain RFC 5424 syslog
# CEF is an open standard compatible with ArcSight, QRadar, Wazuh, LogRhythm, etc.
SIEM_CEF_ENABLED=false

# ── Remediation Behaviour ────────────────────────────────────
# DRY_RUN=true   → AI analyses and logs what it would do, but makes NO changes (safe default)
# DRY_RUN=false  → combined with AUTO_REMEDIATE=true, AI actually executes changes
DRY_RUN=true

# AUTO_REMEDIATE must be explicitly set to true to allow live changes.
# When false, the system only runs in dry-run analysis mode even if DRY_RUN=false.
AUTO_REMEDIATE=false
# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins. No wildcards in production.
CORS_ORIGINS=http://localhost:3000

# ── Audit Log (AU-2 / AU-9 — FedRAMP / IL6) ─────────────────
# Path to the immutable hash-chained JSONL audit log.
AUDIT_LOG_FILE=audit.jsonl
# AUDIT_BACKENDS: comma-separated — file | redis | siem
AUDIT_BACKENDS=file
# HMAC key for tamper-evident log entries (required for production).
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
AUDIT_HMAC_KEY=

# ── Secrets Backend (SC-28 / IA-5) ──────────────────────────
# SECRETS_BACKEND: env (default) | aws_sm | vault
SECRETS_BACKEND=env
# AWS Secrets Manager (when SECRETS_BACKEND=aws_sm)
AWS_REGION=us-east-1
USE_FIPS=false     # Set true for IL4+ / FedRAMP — enables FIPS 140-2 endpoint
# HashiCorp Vault (when SECRETS_BACKEND=vault)
VAULT_ADDR=https://vault.example.com
VAULT_TOKEN=
VAULT_MOUNT=secret

# ── HMAC Key for fingerprint hashing (SC-28) ─────────────────
# Used to HMAC-SHA256 IP / User-Agent fingerprints instead of plain SHA-256.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
DNA_HMAC_KEY=
